# ==============================================================================
# CONFIGURAÇÃO NGINX EXEMPLO — MELHORA PRUDENTE (VPS REVERSE PROXY)
# Arquivo: /etc/nginx/sites-available/melhoraprudente.com.br
# ==============================================================================

# Redirecionamento HTTP -> HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name melhoraprudente.com.br www.melhoraprudente.com.br;

    return 301 https://$host$request_uri;
}

# Servidor Principal HTTPS
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name melhoraprudente.com.br www.melhoraprudente.com.br;

    # Certificados SSL (Let's Encrypt / Certbot)
    ssl_certificate /etc/letsencrypt/live/melhoraprudente.com.br/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/melhoraprudente.com.br/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Compressão Gzip
    gzip on;
    gzip_proxied any;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript image/svg+xml;
    gzip_comp_level 6;

    # Headers de Segurança
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Proxy para Aplicação Next.js (Porta 3000)
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        
        # WebSockets e Conexões Persistentes
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        
        # Headers HTTP
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 60s;
        proxy_connect_timeout 60s;
    }

    # Cache para arquivos estáticos do Next.js
    location /_next/static/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        
        # Cache no navegador por 1 ano para ativos com hash
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # Arquivos estáticos da pasta public
    location /public/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }

    # Logs do Nginx
    access_log /var/log/nginx/melhora_prudente_access.log;
    error_log /var/log/nginx/melhora_prudente_error.log;
}
