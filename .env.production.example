# ==============================================================================
# MELHORA PRUDENTE - VARIÁVEIS DE AMBIENTE (PRODUÇÃO / VPS)
# ==============================================================================

# Supabase Public Credentials (Acessível no Front-end e Server)
NEXT_PUBLIC_SUPABASE_URL=https://sua-instancia.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anonima-publica

# Supabase Service Role Key (USAR APENAS NO SERVIDOR / WORKER VPS - NUNCA EXPOR NO CLIENTE)
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-privada

# Google Gemini AI API Key (Usado no AI Service e Worker no Servidor)
GEMINI_API_KEY=sua-chave-api-gemini

# Garimpo Worker Configurations
WORKER_INTERVAL_MINUTES=15
WORKER_BATCH_SIZE=3
WORKER_TIMEOUT_MS=60000
NODE_ENV=production
